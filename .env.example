# Application
NODE_ENV=development
PORT=3001

# CORS — comma-separated origins, or * to allow all
CORS_ORIGIN=http://localhost:3000

# Logging — fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=debug

# Database (Postgres). Matches the credentials in docker-compose.yml.
DATABASE_URL=postgresql://feedige:feedige@localhost:5432/feedige?schema=public
