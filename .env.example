# Application
NODE_ENV=development
PORT=3001

# Host port docker-compose publishes the API on (override if 3001 is taken).
API_PORT=3001

# CORS — comma-separated origins, or * to allow all
CORS_ORIGIN=http://localhost:3000

# Logging — fatal|error|warn|info|debug|trace|silent
LOG_LEVEL=debug

# Database (Postgres). Credentials match docker-compose.yml.
#
# POSTGRES_PORT is the HOST port docker-compose publishes Postgres on. Default
# is 5432; change it (and the port in DATABASE_URL below) if 5432 is already in
# use on your machine.
POSTGRES_PORT=5432
DATABASE_URL=postgresql://feedige:feedige@localhost:5432/feedige?schema=public
