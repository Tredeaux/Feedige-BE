// Prisma schema — https://pris.ly/d/prisma-schema
//
// Conventions:
//  - Tables/columns are snake_case in Postgres (via @map/@@map); the generated
//    Prisma client stays camelCase (JS convention).
//  - Primary keys are UUIDs generated by Postgres (gen_random_uuid(), built into
//    PG13+), so the database is authoritative for id generation.
//  - Foreign-key columns are explicitly indexed (Postgres does not auto-index
//    them) to keep joins and lookups fast.
//  - Status/sentiment/priority/role are VARCHARs (not enums) for flexibility —
//    new values don't require a schema migration. See docs/decisions.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// People who submit or triage feedback.
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String?  @db.VarChar(100)
  email        String   @unique @db.VarChar(255)
  // Default is the least-privileged role; triage/admin must be granted explicitly
  // (seeded admin, or a future admin-only promotion endpoint).
  role         String   @default("member") @db.VarChar(50)
  // Set only for accounts that can sign in (admin/triage). Null for users who
  // were created implicitly by submitting feedback.
  passwordHash String?  @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations (back-references)
  submittedFeedback Feedback[]
  analyses          FeedbackAnalysis[]
  auditLogs         AuditLog[]

  @@map("users")
}

/// A piece of raw product feedback awaiting / undergoing triage.
model Feedback {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rawText       String   @map("raw_text") @db.Text
  source        String   @default("web") @db.VarChar(50)
  submittedById String?  @map("submitted_by") @db.Uuid
  status        String   @default("pending") @db.VarChar(20) // pending, reviewed, actioned, archived
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // The submitter may be deleted without losing the feedback.
  submittedBy User?              @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  analyses    FeedbackAnalysis[]
  auditLogs   AuditLog[]

  @@index([status]) // triage queries filter by status
  @@index([submittedById]) // FK lookups
  @@index([createdAt]) // recent-first listing
  @@map("feedback")
}

/// AI analysis of a piece of feedback. Multiple versions allowed per feedback
/// (re-analyses), uniquely identified by (feedback_id, version).
model FeedbackAnalysis {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackId         String   @map("feedback_id") @db.Uuid
  version            Int      @default(1)
  sentiment          String   @db.VarChar(20)
  priority           String   @db.VarChar(20)
  summary            String?  @db.Text
  confidence         Decimal  @db.Decimal(3, 2)
  keyThemes          String[] @map("key_themes")
  recommendedActions String[] @map("recommended_actions")
  modelUsed          String   @default("llama-3.1-70b") @map("model_used") @db.VarChar(100)
  analyzedAt         DateTime @default(now()) @map("analyzed_at") @db.Timestamptz(6)
  analyzedById       String?  @map("analyzed_by") @db.Uuid

  // Deleting feedback removes its analyses; the analyst may be deleted safely.
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  analyzedBy User?    @relation(fields: [analyzedById], references: [id], onDelete: SetNull)

  // One row per (feedback, version); the leftmost column also indexes feedbackId lookups.
  @@unique([feedbackId, version])
  @@index([analyzedById])
  @@map("feedback_analysis")
}

/// Append-only audit trail of actions taken against feedback.
model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  feedbackId String?  @map("feedback_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100) // e.g. analysis_created, status_changed, re_analyzed
  oldValue   Json?    @map("old_value") @db.JsonB
  newValue   Json?    @map("new_value") @db.JsonB
  notes      String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  feedback Feedback? @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([feedbackId, createdAt]) // fetch a feedback's history in order
  @@index([userId]) // FK lookups
  @@map("audit_log")
}
